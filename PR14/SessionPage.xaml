<Page x:Class="PR14.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR14"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SessionPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Name="TxtHeader" FontSize="18" Margin="10"/>

        <UniformGrid Name="SeatContainer" Grid.Row="1" Columns="5" Margin="20"/>

        <DockPanel Grid.Row="2" Margin="10" HorizontalAlignment="Left">
            <Button Content="Назад" Click="BtnBack_Click" Width="80" Height="30" DockPanel.Dock="Left"/>
        </DockPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock Name="TxtPrice" VerticalAlignment="Center" Margin="10"/>
            <Button Content="Оформить билет" Click="BtnBook_Click" Width="150" Height="30"/>
        </StackPanel>
    </Grid>
</Page>
