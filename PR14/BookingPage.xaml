<Page x:Class="PR14.BookingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление билета">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <TextBlock Text="ПОДТВЕРЖДЕНИЕ ЗАКАЗА" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border BorderBrush="Black" BorderThickness="1" Padding="20" Background="#F9F9F9">
                <StackPanel>
                    <TextBlock Name="TxtMovieTitle" FontSize="18" FontWeight="SemiBold" Margin="0,5"/>
                    <Separator Margin="0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Зал:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                        <TextBlock Name="TxtHall" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right"/>

                        <TextBlock Text="Дата и время:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                        <TextBlock Name="TxtDateTime" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right"/>

                        <TextBlock Text="Выбранное место:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                        <TextBlock Name="TxtSeat" Grid.Row="2" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Margin="0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="К оплате: " FontSize="16"/>
                        <TextBlock Name="TxtTotalPrice" FontSize="18" Foreground="Green" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2" Margin="0,20,0,0">
                <Button Content="Отмена" Click="BtnCancel_Click" Margin="5" Height="35" Background="LightGray"/>
                <Button Content="Подтвердить" Click="BtnConfirm_Click" Margin="5" Height="35" Background="LightGreen" FontWeight="Bold"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Page>