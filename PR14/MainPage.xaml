<Page x:Class="PR14.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная - Кинотеатр">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#F0F0F0">
            <Button Content="Личный кабинет" Click="BtnProfile_Click" Margin="5" Padding="10,5"/>

            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox Name="TxtSearch" Width="150" Height="25" TextChanged="TxtSearch_TextChanged" VerticalContentAlignment="Center"/>

            <ComboBox Name="ComboSort" Width="130" Height="25" Margin="10,0" SelectionChanged="ComboSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="По названию"/>
                <ComboBoxItem Content="По рейтингу"/>
            </ComboBox>

            <Button Name="BtnLogin" Content="Войти" Click="BtnLogin_Click" Margin="10,5" Padding="15,5"/>
        </StackPanel>

        <ListView Name="LViewMovies" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="LViewMovies_MouseDoubleClick">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="10" Width="180" Background="White">
                        <StackPanel>
                            <Image Source="{Binding ImagePath}" Height="220" Stretch="UniformToFill" Margin="2"/>

                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="5,2" TextAlignment="Center" TextWrapping="Wrap"/>

                            <Grid Margin="5">
                                <TextBlock Text="{Binding Rating, StringFormat=⭐ {0}}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AgeRating, StringFormat={}{0}+}" HorizontalAlignment="Right" Foreground="Red" FontWeight="Bold"/>
                            </Grid>

                            <TextBlock Text="{Binding StartDate, StringFormat=с {0:dd.MM.yyyy}}" FontSize="10" Foreground="Gray" Margin="5,0,5,5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>