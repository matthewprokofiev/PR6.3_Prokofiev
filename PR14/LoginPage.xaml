<Page x:Class="PR14.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR14"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="ВХОД" FontSize="24" HorizontalAlignment="Center" Margin="10"/>

            <TextBlock Text="Логин:"/>
            <TextBox Name="TxtLogin" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox Name="TxtPassword" Margin="0,5,0,20" Height="25"/>

            <Button Content="Войти" Click="BtnLogin_Click" Height="35" Background="LightBlue"/>
            <StackPanel x:Name="CaptchaPanel"
            Visibility="Collapsed"
            Margin="0,10,0,10">

                <TextBlock Text="Введите капчу:"
               FontSize="14"
               Margin="0,0,0,5"/>

                <Image x:Name="CaptchaImage"
           Width="160"
           Height="50"
           HorizontalAlignment="Left"
           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtCaptcha"
             Width="160"
             HorizontalAlignment="Left"
             FontSize="14"
             Margin="0,0,0,5"/>

                <Button x:Name="BtnRefreshCaptcha"
            Content="🔄 Обновить капчу"
            Width="160"
            HorizontalAlignment="Left"
            Click="BtnRefreshCaptcha_Click"/>

            </StackPanel>
            <Button Content="Регистрация" Click="BtnReg_Click" Margin="0,10" Background="Transparent" BorderThickness="0" Foreground="Blue" Cursor="Hand"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="Transparent" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>
