<Page x:Class="PR14.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR14"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <StackPanel Margin="10">
            <TextBlock Name="TxtUser" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Ваши билеты:" Margin="0,20,0,5"/>
            <DataGrid Name="DGridTickets" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фильм" Binding="{Binding Sessions.Movies.Title}"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Sessions.SessionDate}"/>
                    <DataGridTextColumn Header="Место" Binding="{Binding SeatNumber}"/>
                </DataGrid.Columns>
            </DataGrid>
            <Button Content="На главную" Click="BtnHome_Click" Margin="0,20"/>
        </StackPanel>
    </Grid>
</Page>
